{
  "name": "strip-comments-js",
  "version": "1.0.6",
  "description": "Strip comments from JavaScript and TypeScript code",
  "license": "Apache-2.0",
  "type": "module",
  "main": "lib.js",
  "bin": {
    "strip-comments-js": "bin.js"
  },
  "engines": {
    "node": "^24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/ericcornelissen/strip-comments-js.git"
  },
  "bugs": {
    "url": "https://gitlab.com/ericcornelissen/strip-comments-js/-/work_items"
  },
  "author": {
    "name": "Eric Cornelissen",
    "email": "ericornelissen@gmail.com",
    "url": "https://ericcornelissen.dev/"
  },
  "keywords": [
    "strip",
    "comment",
    "comments",
    "build",
    "transpile",
    "clean",
    "minify"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "bin.js",
    "lib.js",
    "main.js",
    "package.json"
  ],
  "devDependencies": {
    "fast-check": "4.6.0",
    "prettier": "3.8.2"
  },
  "scripts": {
    "_prettier": "prettier '**/*.{js,md,yml}'",
    "check": "npm run _prettier -- --check && npm run test",
    "format": "npm run _prettier -- --write",
    "test": "npm run test:unit && npm run test:bin",
    "test:bin": "node --test 'bin.test.js'",
    "test:unit": "node --test 'main.test.js'"
  }
}
